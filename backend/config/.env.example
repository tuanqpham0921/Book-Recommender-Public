# Copy to config/.env and set secrets locally. Do not commit .env.
# Single file for the app: all keys use the prefixes below (APP_, OPENAI_, POSTGRES_).

# --- Application ---
APP_NAME=book-recommender-backend
APP_ENVIRONMENT=development
# Comma-separated origins, JSON array, or * for all
APP_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
APP_EXPORT_DIR=logs/
APP_DATA_DIR=data/
APP_EXAMPLE_PROMPT_DIR=data/prompt_example/

# --- PostgreSQL (SQLAlchemy / docker-compose postgres service) ---
# When running the API inside docker-compose, override host to the DB service name
# (see docker-compose.yml `environment` on the app service).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=book_recommender
POSTGRES_USER=postgres
POSTGRES_PASSWORD=(your_secure_password_here)
POSTGRES_MIN_CONNECTIONS=5
POSTGRES_MAX_CONNECTIONS=20

# --- OpenAI ---
OPENAI_API_KEY=(your_openai_api_key_here)
OPENAI_BASE_MODEL=gpt-4.1-mini
OPENAI_TOKENIZER_ENCODING=o200k_base
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1024