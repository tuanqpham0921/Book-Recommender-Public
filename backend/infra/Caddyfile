# Global options
{
    # Enable admin API on localhost:2019
    admin localhost:2019
    
    # Auto HTTPS configuration
    # email your-email@example.com  # Uncomment and add your email for production SSL
}

# Development configuration
:80 {
    # Reverse proxy to FastAPI backend
    reverse_proxy app:8000
    
    # Logging
    log {
        output stdout
        level INFO
    }
}

