# Cloud Run Environment Variables Template
# Copy this file to env-vars.yaml and fill in your actual values

# For Cloud SQL (replace with your actual values)
DATABASE_URL: "postgresql://book_user:YOUR_PASSWORD@/book_recommender?host=/cloudsql/PROJECT_ID:REGION:INSTANCE"
POSTGRES_PORT: "5432"
POSTGRES_DB: "book_recommender"
POSTGRES_USER: "book_user"
POSTGRES_PASSWORD: "your_secure_password_here"

# For local development (uncomment to use SQLite instead)
# DATABASE_URL: "sqlite:///app/data/local.db"
REDIS_URL: "redis://localhost:6379/0"
OPENAI_API_KEY: "your_openai_api_key_here"
OPENAI_BASE_MODEL: "gpt-4o-mini"
OPENAI_TOKENIZER_ENCODING: "o200k_base"
OPENAI_EMBEDDING_MODEL: "text-embedding-3-large"
OPENAI_EMBEDDING_DIMENSIONS: "1024"
ALLOW_ORIGINS: "https://your-frontend-domain.com"
DEBUG: "False"
APP_NAME: "Book Recommender API"
VERSION: "1.0.0"
HOST: "0.0.0.0"